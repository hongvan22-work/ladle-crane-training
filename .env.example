# Database - Railway cung cấp sau khi tạo PostgreSQL service
DATABASE_URL="postgresql://username:password@host:5432/dbname"

# NextAuth - tạo bằng lệnh: openssl rand -base64 32
NEXTAUTH_SECRET="your-random-secret-here"

# URL của app sau khi deploy lên Railway
NEXTAUTH_URL="https://your-app.railway.app"
